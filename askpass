# Fallback dialogs
# --------------------------------------------------------------------------- #

def _plain_context(command: str, reason: str) -> str:
    sections = [f"Command:\n{command}"]
    if reason:
        sections.append(f"Reason:\n{reason}")
    return "\n\n".join(sections)


def run_zenity(prompt: str, command: str, reason: str, callers: list[ProcessInfo]) -> int:
    body = [f"<b>{html.escape(prompt)}</b>", html.escape(command)]
    if reason:
        body.append(html.escape(reason))
    text = "\n\n".join(body)

    cmd = [
        "zenity",
        "--forms",
        "--title",
        APP_TITLE,
        "--text",
        text,
        "--add-password",
        "Password",
        "--separator",
        "",
        "--ok-label",
        "Allow",
        "--cancel-label",
        "Deny",
    ]

    completed = subprocess.run(cmd, text=True, stdout=subprocess.PIPE)
    if completed.returncode != 0:
        return completed.returncode

    emit_secret(completed.stdout.rstrip("\n"))
    return 0


def run_kdialog(prompt: str, command: str, reason: str, callers: list[ProcessInfo]) -> int:
    message = f"{prompt}\n\n{_plain_context(command, reason)}"

    completed = subprocess.run(
        ["kdialog", "--title", APP_TITLE, "--password", message],
        text=True,
        stdout=subprocess.PIPE,
    )
    if completed.returncode != 0:
        return completed.returncode

    emit_secret(completed.stdout.rstrip("\n"))
    return 0


def run_tty(prompt: str, command: str, reason: str, callers: list[ProcessInfo]) -> int:
    import getpass

    print(APP_TITLE, file=sys.stderr)
    print(f"Prompt: {prompt}", file=sys.stderr)
    print(f"Command: {command}", file=sys.stderr)
    if reason:
        print(f"Reason: {reason}", file=sys.stderr)

    try:
        secret = getpass.getpass("Password: ")
    except (EOFError, KeyboardInterrupt):
        return 1

    emit_secret(secret)
    return 0


def have_display() -> bool:
    return bool(os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY"))


def main() -> int:
    callers = parent_processes()
    prompt = prompt_text()
    command = command_text(callers)
    reason = reason_text()

    if os.environ.get("ASKPASS_TERMINAL") == "1":
        return run_tty(prompt, command, reason, callers)

    if have_display():
        try:
            import gi  # noqa: F401

            return run_gtk(prompt, command, reason, callers)
        except Exception:
            pass

        if shutil.which("zenity"):
            return run_zenity(prompt, command, reason, callers)

        if shutil.which("kdialog"):
            return run_kdialog(prompt, command, reason, callers)

    return run_tty(prompt, command, reason, callers)


if __name__ == "__main__":
    raise SystemExit(main())
