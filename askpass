#!/usr/bin/env python3
"""Small GUI askpass helper.

The secret is written to stdout, as required by SSH_ASKPASS/GIT_ASKPASS/SUDO_ASKPASS.
All context is shown in the dialog and never written next to the secret.
"""

from __future__ import annotations

import html
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass


APP_TITLE = "Authentication Required"
APP_ID = "org.physsec.askpass"
ENV_COMMAND = "ASKPASS_COMMAND"
ENV_REASON = "ASKPASS_REASON"


@dataclass(frozen=True)
class ProcessInfo:
    pid: int
    command: str


def read_cmdline(pid: int) -> str:
    try:
        with open(f"/proc/{pid}/cmdline", "rb") as proc_file:
            raw = proc_file.read()
    except OSError:
        return ""

    parts = [part.decode(errors="replace") for part in raw.split(b"\0") if part]
    return " ".join(parts)


def read_comm(pid: int) -> str:
    try:
        with open(f"/proc/{pid}/comm", "rb") as proc_file:
            return proc_file.read().rstrip(b"\n").decode(errors="replace")
    except OSError:
        return ""


def process_info(pid: int) -> ProcessInfo:
    return ProcessInfo(pid=pid, command=read_cmdline(pid) or read_comm(pid) or "unknown")


def parent_processes(limit: int = 3) -> list[ProcessInfo]:
    processes: list[ProcessInfo] = []
    pid = os.getppid()

    for _ in range(limit):
        if pid <= 1:
            break

        processes.append(process_info(pid))

        try:
            with open(f"/proc/{pid}/stat", "rb") as proc_file:
                stat = proc_file.read()
            pid = int(stat.rsplit(b")", 1)[1].split()[1])
        except (OSError, IndexError, ValueError):
            break

    return processes


def prompt_text() -> str:
    return " ".join(sys.argv[1:]).strip() or "Enter your password to continue"


def command_text(callers: list[ProcessInfo]) -> str:
    explicit = os.environ.get(ENV_COMMAND, "").strip()
    if explicit:
        return explicit
    if callers:
        return callers[0].command
    return "unknown"


def reason_text() -> str:
    """Return the caller-supplied reason, or an empty string if none was given."""
    return os.environ.get(ENV_REASON, "").strip()


def emit_secret(secret: str) -> None:
    sys.stdout.write(secret)
    sys.stdout.write("\n")


# --------------------------------------------------------------------------- #
# GTK 4 / libadwaita dialog (primary path)
# --------------------------------------------------------------------------- #

def run_gtk(prompt: str, command: str, reason: str, callers: list[ProcessInfo]) -> int:
    import gi

    gi.require_version("Gtk", "4.0")
    gi.require_version("Adw", "1")
    from gi.repository import Adw, Gio, Gtk

    state = {"secret": None}

    app = Adw.Application(application_id=APP_ID, flags=Gio.ApplicationFlags.NON_UNIQUE)

    def on_activate(application: Adw.Application) -> None:
        window = Adw.ApplicationWindow(application=application)
        window.set_title(APP_TITLE)
        window.set_default_size(420, -1)
        window.set_resizable(False)

        def deny() -> None:
            window.close()

        def allow() -> None:
            state["secret"] = password_row.get_text()
            window.close()

        # Escape denies.
        key = Gtk.EventControllerKey()

        def on_key(_ctrl, keyval, _code, _mods) -> bool:
            from gi.repository import Gdk

            if keyval == Gdk.KEY_Escape:
                deny()
                return True
            return False

        key.connect("key-pressed", on_key)
        window.add_controller(key)

        toolbar = Adw.ToolbarView()
        header = Adw.HeaderBar()
        header.add_css_class("flat")
        header.set_show_title(False)
        toolbar.add_top_bar(header)

        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
        content.set_margin_top(8)
        content.set_margin_bottom(24)
        content.set_margin_start(24)
        content.set_margin_end(24)

        icon = Gtk.Image.new_from_icon_name("dialog-password-symbolic")
        icon.set_pixel_size(56)
        icon.add_css_class("accent")
        content.append(icon)

        title = Gtk.Label(label=prompt)
        title.add_css_class("title-2")
        title.set_wrap(True)
        title.set_justify(Gtk.Justification.CENTER)
        content.append(title)

        if reason:
            subtitle = Gtk.Label(label=reason)
            subtitle.add_css_class("dim-label")
            subtitle.set_wrap(True)
            subtitle.set_justify(Gtk.Justification.CENTER)
            content.append(subtitle)

        # Command, shown as a monospace card so it stands out and is selectable.
        command_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        command_card.add_css_class("card")
        command_label = Gtk.Label(label=command)
        command_label.add_css_class("monospace")
        command_label.set_wrap(True)
        command_label.set_wrap_mode(2)  # WORD_CHAR
        command_label.set_selectable(True)
        command_label.set_xalign(0.0)
        command_label.set_margin_top(12)
        command_label.set_margin_bottom(12)
        command_label.set_margin_start(14)
        command_label.set_margin_end(14)
        command_card.append(command_label)
        content.append(command_card)

        # Password entry.
        entry_group = Adw.PreferencesGroup()
        password_row = Adw.PasswordEntryRow(title="Password")
        password_row.connect("entry-activated", lambda _row: allow())
        entry_group.add(password_row)
        content.append(entry_group)

        # Process chain, collapsed by default — auditing detail, not everyday noise.
        if callers:
            detail_group = Adw.PreferencesGroup()
            expander = Adw.ExpanderRow(title="Process details")
            expander.set_subtitle(f"{len(callers)} calling process"
                                  + ("es" if len(callers) != 1 else ""))
            for caller in callers:
                row = Adw.ActionRow()
                row.set_use_markup(False)  # command text is literal, not Pango markup
                row.set_title(caller.command)
                row.set_subtitle(f"PID {caller.pid}")
                row.set_title_lines(1)
                row.add_css_class("monospace")
                expander.add_row(row)
            detail_group.add(expander)
            content.append(detail_group)

        # Action buttons.
        buttons = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        buttons.set_homogeneous(True)
        buttons.set_margin_top(6)

        deny_button = Gtk.Button(label="Deny")
        deny_button.connect("clicked", lambda _btn: deny())
        buttons.append(deny_button)

        allow_button = Gtk.Button(label="Allow")
        allow_button.add_css_class("suggested-action")
        allow_button.connect("clicked", lambda _btn: allow())
        buttons.append(allow_button)

        content.append(buttons)

        toolbar.set_content(content)
        window.set_content(toolbar)
        window.present()
        password_row.grab_focus()

    app.connect("activate", on_activate)
    app.run([])

    if state["secret"] is None:
        return 1
    emit_secret(state["secret"])
    return 0


